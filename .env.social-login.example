PORT=3000
SESSION_SECRET=replace-with-a-long-random-secret

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_replace_me
STRIPE_PRICE_ID_PILOT=price_replace_me

# Allowed hosts for origin validation (comma-separated, no spaces)
# In production, set this to your domain, e.g. ALLOWED_HOSTS=sim2real.dev
ALLOWED_HOSTS=sim-2-real.com

# Social Login OAuth Credentials
# Google OAuth 2.0 (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://sim-2-real.com/api/auth/google/callback

# Apple Sign In (get from https://developer.apple.com/account/resources/identifiers/list/serviceId)
APPLE_CLIENT_ID=your_apple_client_id_here
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_KEY_ID=your_apple_key_id_here
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
your_apple_private_key_here
-----END PRIVATE KEY-----
APPLE_REDIRECT_URI=https://sim-2-real.com/api/auth/apple/callback

# n8n Webhook for Forgot Password
N8N_WEBHOOK_URL=https://n8n.developer312.com/webhook/forgot-password
N8N_API_KEY=your_n8n_api_key_here

# Email Configuration (hello@developer312.com)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@developer312.com
SMTP_PASS=your_app_password_here

# PostgreSQL (Railway will set this automatically)
DATABASE_URL=postgresql://user:pass@host:5432/sim2real

# Redis (for session store in production)
REDIS_URL=redis://localhost:6379

# Frontend URL
NEXT_PUBLIC_APP_URL=https://sim-2-real.com
