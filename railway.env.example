# Sim2Real Railway Environment Variables
# Copy this file to Railway as environment variables

# ── Required ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Session secret - generate a random 32+ character string
# openssl rand -hex 32
SESSION_SECRET=replace-with-a-secure-random-secret-min-32-chars

# ── Stripe Billing ──────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_replace_me_or_sk_test_for_staging
STRIPE_PRICE_ID_PILOT=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe webhook URL after deploy:
# https://your-railway-app.up.railway.app/api/webhooks/stripe

# ── Allowed Hosts ───────────────────────────────────────────────────────────
# Comma-separated list of allowed host headers (no spaces)
# Set to your production domain
ALLOWED_HOSTS=your-app.up.railway.app,yourdomain.com

# ── Optional ────────────────────────────────────────────────────────────────
# PBKDF2 iterations for password hashing (default: 100000)
PBKDF2_ITERATIONS=100000

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
